{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/session-update.sh" } ] }
    ],
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [
        { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/secrets-guard.sh" },
        { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/destructive-git-guard.sh" }
      ] },
      { "matcher": "Edit|Write|MultiEdit", "hooks": [
        { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/secrets-guard.sh" },
        { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/core-guard.sh" }
      ] }
    ]
  }
}
